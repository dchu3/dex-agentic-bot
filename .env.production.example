# =============================================================================
# Production Environment — DEX Analysis MCP Server
# =============================================================================
# Copy to .env and fill in all required values before deploying.

# --- Required ---

# Public domain for TLS certificate (e.g., api.yourdomain.com)
DOMAIN=api.yourdomain.com

# Gemini API key for AI-powered analysis
GEMINI_API_KEY=

# Solana wallet address that receives USDC payments
SERVER_WALLET_ADDRESS=

# --- Payment Configuration ---

# Price per analysis in USDC (default: 0.75)
SERVER_PRICE_ANALYZE=0.75

# Solana network: "solana" (mainnet) or "solana-devnet"
SERVER_SOLANA_NETWORK=solana

# x402 facilitator URL (default: PayAI mainnet)
# PayAI (no auth): https://facilitator.payai.network
# Coinbase CDP: https://api.cdp.coinbase.com/platform/v2/x402
# Devnet testing: https://x402.org/facilitator
X402_FACILITATOR_URL=https://facilitator.payai.network

# --- Rate Limiting ---

# Global rate limit window in milliseconds (default: 900000 = 15 min)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window globally (default: 100)
RATE_LIMIT_MAX=100

# Max requests per minute to /mcp endpoint (default: 20)
RATE_LIMIT_MCP_MAX=20

# --- CORS ---

# Comma-separated allowed origins (default: * for dev; restrict in production)
# Example: https://app.yourdomain.com,https://yourdomain.com
CORS_ALLOWED_ORIGINS=https://app.yourdomain.com

# --- Solana RPC ---

# Use a private RPC for reliability (public RPC is heavily rate-limited)
# Helius: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# QuickNode: https://YOUR_ENDPOINT.solana-mainnet.quiknode.pro/YOUR_KEY
SOLANA_RPC_URL=

# --- Gemini Model ---
GEMINI_MODEL=gemini-2.5-flash
